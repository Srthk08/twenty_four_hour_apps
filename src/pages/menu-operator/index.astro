    };

    window.downloadText = function(photoId) {
      console.log('Download text for photo:', photoId);
      // Implement download functionality
    };
    
    // Initial load uses real data only
    console.log('🔄 Script loaded - Loading real data...');
    loadRealData();
    
</script>
